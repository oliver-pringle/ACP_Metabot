{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Sqlite": "Data Source=acp_metabot.db;Cache=Shared"
  },
  "Indexer": {
    "Source": "acp-api",
    "SourcePath": "data/seed/offerings.example.json",
    "ApiBaseUrl": "https://acpx.virtuals.io/",
    "ApiPageSize": 100,
    "ApiMaxPages": 0,
    "ApiRequestDelayMs": 50,
    "ApiSortBy": "usageCount",
    "ApiSortOrder": "desc",
    "IntervalSeconds": 120,
    "EmbeddingConcurrency": 64
  },
  "Embeddings": {
    "Provider": "voyage",
    "Model": "voyage-finance-2"
  },
  "Claude": {
    "Model": "claude-sonnet-4-6"
  },
  "Reputation": {
    "WarmerTopN": 500,
    "WarmerBudgetMinutes": 60,
    "WarmerConcurrency": 4,
    "ContractDeployBlock": 0
  }
}
