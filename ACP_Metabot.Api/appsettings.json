{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Sqlite": "Data Source=acp_metabot.db;Cache=Shared"
  },
  "Indexer": {
    "Source": "acp-api",
    "SourcePath": "data/seed/offerings.example.json",
    "ApiBaseUrl": "https://acpx.virtuals.io/",
    "ApiPageSize": 100,
    "ApiMaxPages": 0,
    "ApiRequestDelayMs": 50,
    "ApiSortBy": "usageCount",
    "ApiSortOrder": "desc",
    "IntervalSeconds": 120,
    "EmbeddingConcurrency": 64
  },
  "Embeddings": {
    "Provider": "voyage",
    "Model": "voyage-finance-2",
    "Fallback": {
      "Enabled": false,
      "Model": "embed-english-v3.0"
    }
  },
  "Claude": {
    "Model": "claude-sonnet-4-6"
  },
  "Reputation": {
    "WarmerTopN": 500,
    "WarmerBudgetMinutes": 60,
    "WarmerConcurrency": 4,
    "ContractDeployBlock": 44427013,
    "ChunkSize": 10000,
    "MaxFirstScanDays": 90
  },
  "TheChainlinkBot": {
    "BaseUrl": "http://acp-chainlinkbot-api:5000/",
    "ApiKey": ""
  },
  "Backup": {
    "Enabled": true,
    "HourUtc": 4,
    "KeepDays": 7,
    "Directory": "/data/backups",
    "BaseName": "acp_metabot"
  },
  "Feeds": {
    "Enabled": false,
    "HourUtc": 5,
    "TopN": 50,
    "MinScore": 50,
    "BatchSize": 5,
    "Sync": {
      "Enabled": false,
      "IntervalMinutes": 60,
      "BatchSize": 5,
      "MaxAgents": 500,
      "OwnAgentAddress": "",
      "OwnScoreThreshold": 30
    }
  }
}
