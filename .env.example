# Top-level env (used by docker-compose).
# The ACP sidecar reads its own credentials from acp-v2/.env — see acp-v2/.env.example.

# Override the default ASP.NET environment if you want development logging in containers:
# ASPNETCORE_ENVIRONMENT=Development

# Required — service credentials and shared internal auth.
VOYAGE_API_KEY=
ANTHROPIC_API_KEY=
INTERNAL_API_KEY=                  # openssl rand -hex 32

# Optional — public gateway domain. If set, Caddy provisions a Let's Encrypt
# cert for this hostname and reverse-proxies it to the C# API's /v1/* endpoints.
# DNS must be an A record pointing at this VM, NOT proxied (gray cloud on
# Cloudflare). Leave unset to keep the gateway dormant.
# ACP_METABOT_DOMAIN=api.acp-metabot.dev
