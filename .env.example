# Top-level env (used by docker-compose).
# The ACP sidecar reads its own credentials from acp-v2/.env — see acp-v2/.env.example.

# Override the default ASP.NET environment if you want development logging in containers:
# ASPNETCORE_ENVIRONMENT=Development

# Required — service credentials and shared internal auth.
VOYAGE_API_KEY=
ANTHROPIC_API_KEY=
INTERNAL_API_KEY=                  # openssl rand -hex 32

# Optional — public gateway domain. If set, Caddy provisions a Let's Encrypt
# cert for this hostname and reverse-proxies it to the C# API's /v1/* endpoints.
# DNS must be an A record pointing at this VM, NOT proxied (gray cloud on
# Cloudflare). Leave unset to keep the gateway dormant.
# ACP_METABOT_DOMAIN=api.acp-metabot.dev

# v1.7+ Portfolio Risk — cross-bot risk orchestrator.
# Each value here must EQUAL the target bot's own INTERNAL_API_KEY (or
# RevokeBot_API_KEY for RevokeBot). When empty, the corresponding peer is
# treated as unavailable and listed in risk_snapshot's fallbacks[].
# Sweep every dependent bot's .env when rotating these — drift silent-401s
# the cross-bot pipeline (see CLAUDE.md "Cross-bot API key sync").
# LIQUIDGUARD_API_KEY=
# REVOKEBOT_API_KEY=          # NB: target bot reads this header as RevokeBot_API_KEY
# MEVPROTECT_API_KEY=
# EASISSUER_API_KEY=

# Subscription worker for daily_risk_watch. Default OFF. Flip to true after
# the 4 peer keys above are populated AND a curl smoke-test confirms each
# peer is reachable over the acp-shared bridge.
# RISK_WATCH_WORKER_ENABLED=false
# RISK_WATCH_POLL_SECONDS=300
