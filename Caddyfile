# Caddy config for the ACP_Metabot public gateway, sharing the hostname
# with path-routed Resources surfaces for sidecar-only bots that never
# got their own DNS (ChainlinkBot, DeFiEval, AgentEval, LiquidGuard,
# MEVProtect).
#
# Each bot's api container must be on the caddy_proxy external docker
# network so the upstream name resolves. handle_path strips the matched
# prefix so /<botname>/v1/resources/<name> is forwarded as
# /v1/resources/<name>. Each bot must also include api.acp-metabot.dev
# in its ASP.NET AllowedHosts via the ALLOWED_HOSTS env override.

{$ACP_METABOT_DOMAIN:localhost} {
	encode gzip

	handle_path /chainlinkbot/* {
		reverse_proxy acp-chainlinkbot-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle_path /defieval/* {
		reverse_proxy acp-defieval-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle_path /agenteval/* {
		reverse_proxy acp-agenteval-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle_path /liquidguard/* {
		reverse_proxy liquidguard-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle_path /mevprotect/* {
		reverse_proxy mevprotect-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle_path /arenabot/* {
		reverse_proxy arenabot-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle_path /revokebot/* {
		reverse_proxy revokebot-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle_path /easissuer/* {
		reverse_proxy easissuer-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}


	handle_path /oraclebot/* {
		reverse_proxy oraclebot-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle_path /butlerbridgebot/* {
		reverse_proxy butlerbridgebot-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle_path /solanabot/* {
		reverse_proxy solanabot-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle_path /witnessbot/* {
		reverse_proxy witnessbot-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	handle {
		reverse_proxy acp-metabot-api:5000 {
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 14
			mode 0644
		}
		format json
	}
}


# Append this block to /root/ACP_Metabot/Caddyfile on the droplet.
# Reload after editing:  docker exec acp-metabot-caddy caddy reload --config /etc/caddy/Caddyfile

acp-metabot.dev {
	encode gzip zstd
	header {
		defer
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=()"
		Content-Security-Policy "script-src 'self'" "script-src 'self' 'unsafe-inline'"
	}
	reverse_proxy acp-website:5000
}
